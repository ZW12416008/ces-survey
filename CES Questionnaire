    renderRecentList();

    const savedTestModeValue = localStorage.getItem(TEST_MODE_KEY);
    const savedTestMode = savedTestModeValue === null ? true : savedTestModeValue === "1";

    if (savedTestModeValue === null) {
      localStorage.setItem(TEST_MODE_KEY, "1");
    }

    requireInPark = !savedTestMode;
    syncTestModeUI();

    const savedLang = localStorage.getItem(LANG_KEY) || "en";
    setLanguage(savedLang);

    if (savedTestMode) {
      statusKey = "testing";
      updateDynamicStatus();
    }
  }

  function backToParkCenter() {
    map.setCenter(parkCenter);
    map.setZoom(17);
  }

  function locateMe() {
    if (!navigator.geolocation) {
      setStatusByKey("noGeolocation");
      return;
    }

    setStatusByKey("requesting");

    navigator.geolocation.getCurrentPosition(
      function(position) {
        const rawLng = position.coords.longitude;
        const rawLat = position.coords.latitude;
        const [gcjLng, gcjLat] = wgs84ToGcj02(rawLng, rawLat);
        const accuracy = position.coords.accuracy;

        currentPosition = {
          lng: gcjLng,
          lat: gcjLat,
          raw_lng: rawLng,
          raw_lat: rawLat,
          accuracy: accuracy
        };

        inPark = pointInPark(gcjLng, gcjLat);

        document.getElementById("lng").value = gcjLng.toFixed(6);
        document.getElementById("lat").value = gcjLat.toFixed(6);

        if (!currentLocationMarker) {
          currentLocationMarker = new AMap.Marker({
            position: [gcjLng, gcjLat],
            title: "Current Location",
            label: { content: currentLang === "zh" ? "当前位置" : "Current location", direction: "top" }
          });
          map.add(currentLocationMarker);
        } else {
          currentLocationMarker.setPosition([gcjLng, gcjLat]);
          currentLocationMarker.setLabel({ content: currentLang === "zh" ? "当前位置" : "Current location", direction: "top" });
        }

        map.setCenter([gcjLng, gcjLat]);
        map.setZoom(18);

        if (inPark) {
          setStatusByKey("inPark", accuracy);
          consentModal.classList.remove("hidden");
        } else {
          if (requireInPark) {
            setStatusByKey("outParkReq", accuracy);
          } else {
            setStatusByKey("outParkTest", accuracy);
            consentModal.classList.remove("hidden");
          }
        }
      },
      function(error) {
        let key = "fail";
        if (error.code === 1) key = "deny";
        if (error.code === 2) key = "unavailable";
        if (error.code === 3) key = "timeout";
        setStatusByKey(key);
        console.error(error);
      },
      {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 0
      }
    );
  }

  function acceptConsent() {
    if (!document.getElementById("consentCheck").checked) {
      alert(t("dialogs.needCheck"));
      return;
    }
    consentAccepted = true;
    consentModal.classList.add("hidden");
    beforeConsentBox.classList.add("hidden");
    surveyForm.classList.remove("hidden");
    setStatusByKey("formReady");
  }

  surveyForm.addEventListener("submit", async function(e) {
    e.preventDefault();

    if (!currentPosition) {
      alert(t("dialogs.pleaseLocate"));
      return;
    }

    if (requireInPark && !inPark) {
      alert(t("dialogs.notInPark"));
      return;
    }

    if (!consentAccepted) {
      alert(t("dialogs.consentFirst"));
      return;
    }

    const now = new Date();
    const submitTimestamp = formatTimestamp(now);
    const completedAt = formatReadableTime(now);

    let visitPurpose = getCheckboxValues("visit_purpose");
    let parkAttraction = getCheckboxValues("park_attraction");
    let parkLack = getCheckboxValues("park_lack");

    visitPurpose = appendOtherIfChecked(visitPurpose, "visit_purpose_other");
    parkAttraction = appendOtherIfChecked(parkAttraction, "park_attraction_other");
    parkLack = appendOtherIfChecked(parkLack, "park_lack_other");

    const payload = {
      id: submitTimestamp,
      submit_timestamp: submitTimestamp,
      completed_at: completedAt,
      ui_language: currentLang,
      lng: currentPosition.lng,
      lat: currentPosition.lat,
      raw_lng: currentPosition.raw_lng,
      raw_lat: currentPosition.raw_lat,
      accuracy_m: currentPosition.accuracy,
      in_park: inPark,
      test_mode: isTestMode(),
      consent: consentAccepted,

      age: getRadioValue("age"),
      gender: getRadioValue("gender"),
      education: getRadioValue("education"),
      income: getRadioValue("income"),
      visit_frequency: getRadioValue("visit_frequency"),

      visit_purpose: visitPurpose,
      visit_purpose_other: document.getElementById("visit_purpose_other").value.trim(),
      park_attraction: parkAttraction,
      park_attraction_other: document.getElementById("park_attraction_other").value.trim(),
      park_lack: parkLack,
      park_lack_other: document.getElementById("park_lack_other").value.trim(),

      sound_overall: document.getElementById("sound_overall").value,
      sound_attr_pleasant: getRadioValue("sound_attr_pleasant"),
      sound_attr_vibrant: getRadioValue("sound_attr_vibrant"),
      sound_attr_eventful: getRadioValue("sound_attr_eventful"),
      sound_attr_chaotic: getRadioValue("sound_attr_chaotic"),
      sound_attr_annoying: getRadioValue("sound_attr_annoying"),
      sound_attr_monotonous: getRadioValue("sound_attr_monotonous"),
      sound_attr_uneventful: getRadioValue("sound_attr_uneventful"),
      sound_attr_calm: getRadioValue("sound_attr_calm"),
      included_in_formal_results: inPark,

      ces_culture: document.getElementById("ces_culture").value,
      ces_aesthetic: document.getElementById("ces_aesthetic").value,
      ces_leisure: document.getElementById("ces_leisure").value,
      ces_restoration: document.getElementById("ces_restoration").value,
      ces_education: document.getElementById("ces_education").value,
      ces_social: document.getElementById("ces_social").value,
      notes: document.getElementById("notes").value.trim()
    };

    console.log("Display-only payload preview:", payload);
    lastTimestampSaved = submitTimestamp;
    statusKey = "saved";
    alert(t("dialogs.displayOnly"));

    surveyForm.reset();
    consentAccepted = false;
    document.getElementById("consentCheck").checked = false;

    surveyForm.classList.add("hidden");
    beforeConsentBox.classList.remove("hidden");

    renderRecentList();
    updateDynamicStatus();
  });

