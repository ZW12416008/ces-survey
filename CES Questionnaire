</head>
<body>

  <div id="consentModal" class="consent-mask hidden">
    <div class="consent-box">
      <h2 id="consentTitle">知情同意书</h2>
      <div class="consent-content" id="consentContent"></div>
      <div class="option-group">
        <label><input type="checkbox" id="consentCheck"> <span id="consentCheckText">我已阅读并理解以上内容，自愿参加本次调查</span></label>
      </div>
      <div class="submit-row">
        <button class="primary" type="button" onclick="acceptConsent()" id="consentButton">同意并进入问卷</button>
      </div>
    </div>
  </div>

  <div class="page">
    <div class="map-panel">
      <div id="map"></div>
      <div class="toolbar">
        <button type="button" onclick="locateMe()" id="locateBtn">自动定位</button>
        <button type="button" class="secondary" onclick="backToParkCenter()" id="backCenterBtn">回到中心</button>
        <label class="test-toggle-wrap" for="testModeToggle">
          <span id="testModeLabel">测试开关</span>
          <input type="checkbox" id="testModeToggle" onchange="handleTestModeToggle(event)">
        </label>
        <select id="languageSwitcher" class="lang-select" onchange="setLanguage(this.value)">
          <option value="en">English</option>
          <option value="zh">简体中文</option>
        </select>
      </div>
    </div>

    <aside class="side-panel">
      <h1 id="pageTitle">Zhongshan Park CES Survey</h1>
      <div class="desc" id="pageDesc"></div>

      <div class="lang-note" id="langNote"></div>
      <div class="status" id="statusBox">Status: Waiting for location</div>

      <div class="display-banner" id="displayBanner">This is the GitHub Pages display version. It is for demonstrating the questionnaire content and interaction flow only. Online submission is disabled. Responses completed outside Zhongshan Park are not included in the formal study results.</div>

      <div id="beforeConsentBox" class="placeholder-box"></div>

      <form id="surveyForm" class="hidden">
        <div class="field">
          <label id="lngLabel">经度</label>
          <input id="lng" readonly />
        </div>

        <div class="field">
          <label id="latLabel">纬度</label>
          <input id="lat" readonly />
        </div>

        <h2 id="secBasic">一、基本信息</h2>

        <div class="field">
          <label id="qAge">1. 您的年龄是？</label>
          <div class="option-group">
            <label><input type="radio" name="age" value="18岁以下 / Under 18"> <span id="age1">18岁以下</span></label>
            <label><input type="radio" name="age" value="19-60岁 / 19-60"> <span id="age2">19-60岁</span></label>
            <label><input type="radio" name="age" value="60岁及以上 / 60 and above"> <span id="age3">60岁及以上</span></label>
          </div>
        </div>

        <div class="field">
          <label id="qGender">2. 您的性别是？</label>
          <div class="option-inline">
            <label><input type="radio" name="gender" value="男 / Male"> <span id="gender1">男</span></label>
            <label><input type="radio" name="gender" value="女 / Female"> <span id="gender2">女</span></label>
          </div>
        </div>

        <div class="field">
          <label id="qEducation">3. 您的受教育程度是？</label>
          <div class="option-group">
            <label><input type="radio" name="education" value="高中及以下 / High school or below"> <span id="edu1">高中及以下</span></label>
            <label><input type="radio" name="education" value="大专及本科 / College or Bachelor's"> <span id="edu2">大专及本科</span></label>
            <label><input type="radio" name="education" value="硕士及以上 / Master's or above"> <span id="edu3">硕士及以上</span></label>
          </div>
        </div>

        <div class="field">
          <label id="qIncome">4. 您目前的月收入是？</label>
          <div class="option-group">
            <label><input type="radio" name="income" value="0-5000元 / RMB 0-5000"> <span id="income1">0-5000元</span></label>
            <label><input type="radio" name="income" value="5001-10000元 / RMB 5001-10000"> <span id="income2">5001-10000元</span></label>
            <label><input type="radio" name="income" value="10000元及以上 / RMB 10000 and above"> <span id="income3">10000元及以上</span></label>
          </div>
        </div>

        <div class="field">
          <label id="qVisitFreq">5. 您前往公园的平均频率是？</label>
          <div class="option-group">
            <label><input type="radio" name="visit_frequency" value="每周不到1次或1次 / Less than once or once a week"> <span id="freq1">每周不到1次或1次</span></label>
            <label><input type="radio" name="visit_frequency" value="每周2-5次 / 2-5 times a week"> <span id="freq2">每周2-5次</span></label>
            <label><input type="radio" name="visit_frequency" value="每周5次及以上 / 5 times or more a week"> <span id="freq3">每周5次及以上</span></label>
          </div>
        </div>

        <div class="field">
          <label id="qVisitPurpose">6. 您前往公园的主要目的是什么？（多选）</label>
          <div class="option-group">
            <label><input type="checkbox" name="visit_purpose" value="日常散步与短暂停留 / Daily walking and short stay"> <span id="vp1">日常散步与短暂停留</span></label>
            <label><input type="checkbox" name="visit_purpose" value="运动锻炼 / Exercise"> <span id="vp2">运动锻炼</span></label>
            <label><input type="checkbox" name="visit_purpose" value="陪伴儿童活动 / Accompanying children"> <span id="vp3">陪伴儿童活动</span></label>
            <label><input type="checkbox" name="visit_purpose" value="休闲社交与会面交流 / Leisure and social interaction"> <span id="vp4">休闲社交与会面交流</span></label>
            <label><input type="checkbox" name="visit_purpose" value="亲近自然与放松身心 / Contact with nature and relaxation"> <span id="vp5">亲近自然与放松身心</span></label>
            <label><input type="checkbox" name="visit_purpose" value="遛狗或陪伴宠物活动 / Walking dogs or staying with pets"> <span id="vp6">遛狗或陪伴宠物活动</span></label>
            <label><input type="checkbox" name="visit_purpose" value="欣赏/参与文化娱乐活动 / Cultural or recreational participation"> <span id="vp7">欣赏/参与文化娱乐活动</span></label>
            <label><input type="checkbox" name="visit_purpose" value="通行或顺路经过 / Passing through"> <span id="vp8">通行或顺路经过</span></label>
            <div class="inline-other">
              <label><input type="checkbox" name="visit_purpose" value="其他 / Other"> <span id="other1">其他</span></label>
              <input type="text" id="visit_purpose_other" placeholder="请填写其他内容">
            </div>
          </div>
        </div>

        <div class="field">
          <label id="qParkAttraction">7. 您认为公园最吸引您的是什么？（多选）</label>
          <div class="option-group">
            <label><input type="checkbox" name="park_attraction" value="优美的自然景观与生态环境 / Natural scenery and ecological environment"> <span id="pa1">优美的自然景观与生态环境</span></label>
            <label><input type="checkbox" name="park_attraction" value="安静舒适、适合放松的氛围 / Quiet and comfortable atmosphere"> <span id="pa2">安静舒适、适合放松的氛围</span></label>
            <label><input type="checkbox" name="park_attraction" value="鸟鸣、风声等自然声音带来的环境感受 / Natural sounds such as birdsong and wind"> <span id="pa3">鸟鸣、风声等自然声音带来的环境感受</span></label>
            <label><input type="checkbox" name="park_attraction" value="开阔宜人的活动与交往空间 / Pleasant spaces for activity and interaction"> <span id="pa4">开阔宜人的活动与交往空间</span></label>
            <label><input type="checkbox" name="park_attraction" value="丰富便利的运动与休闲设施 / Sports and leisure facilities"> <span id="pa5">丰富便利的运动与休闲设施</span></label>
            <label><input type="checkbox" name="park_attraction" value="儿童活动空间或亲子友好环境 / Child-friendly space"> <span id="pa6">儿童活动空间或亲子友好环境</span></label>
            <label><input type="checkbox" name="park_attraction" value="文化展示、游览观赏或娱乐活动氛围 / Cultural display and recreational atmosphere"> <span id="pa7">文化展示、游览观赏或娱乐活动氛围</span></label>
            <div class="inline-other">
              <label><input type="checkbox" name="park_attraction" value="其他 / Other"> <span id="other2">其他</span></label>
              <input type="text" id="park_attraction_other" placeholder="请填写其他内容">
            </div>
          </div>
        </div>

        <div class="field">
          <label id="qParkLack">8. 您认为当前公园或您经常前往的公园缺少什么？（多选）</label>
          <div class="option-group">
            <label><input type="checkbox" name="park_lack" value="没什么明显缺少 / Nothing obvious is lacking"> <span id="pl1">没什么明显缺少</span></label>
            <label><input type="checkbox" name="park_lack" value="更丰富的绿化与自然植被 / More greenery and vegetation"> <span id="pl2">更丰富的绿化与自然植被</span></label>
            <label><input type="checkbox" name="park_lack" value="鸟类、昆虫等更丰富的自然生物环境 / Richer biodiversity such as birds and insects"> <span id="pl3">鸟类、昆虫等更丰富的自然生物环境</span></label>
            <label><input type="checkbox" name="park_lack" value="更完善的运动健身设施 / Better sports and fitness facilities"> <span id="pl4">更完善的运动健身设施</span></label>
            <label><input type="checkbox" name="park_lack" value="休憩、儿童或日常活动设施 / Seating, children's or daily-use facilities"> <span id="pl5">休憩、儿童或日常活动设施</span></label>
            <label><input type="checkbox" name="park_lack" value="更安静舒适的休闲氛围 / A quieter and more comfortable atmosphere"> <span id="pl6">更安静舒适的休闲氛围</span></label>
            <label><input type="checkbox" name="park_lack" value="更有特色的文化内容 / More distinctive cultural content"> <span id="pl7">更有特色的文化内容</span></label>
            <div class="inline-other">
              <label><input type="checkbox" name="park_lack" value="其他 / Other"> <span id="other3">其他</span></label>
              <input type="text" id="park_lack_other" placeholder="请填写其他内容">
            </div>
          </div>
        </div>

        <h2 id="secSound">二、声环境感知评估</h2>

        <div class="field">
          <label id="qSoundOverall">9. 总体来说，您如何评价当前周围的声音环境？</label>
          <div class="scale-note" id="soundOverallNote"></div>
          <select id="sound_overall">
            <option value="" id="optSelect">请选择</option>
            <option value="1" id="soundOpt1">1 很差</option>
            <option value="2" id="soundOpt2">2 较差</option>
            <option value="3" id="soundOpt3">3 一般</option>
            <option value="4" id="soundOpt4">4 较好</option>
            <option value="5" id="soundOpt5">5 很好</option>
          </select>
        </div>

        <div class="field">
          <label id="qSoundMatrix">10. 以下是一些用于描述当前声音环境的感知属性。请根据您此刻的真实体验，判断您在多大程度上同意以下描述。</label>
          <div class="scale-note" id="matrixNote"></div>
          <table class="matrix">
            <tr>
              <th id="matrixAttrHead">感知属性</th>
              <th><div>5</div><div class="small" id="matrix5">非常同意</div></th>
              <th><div>4</div><div class="small" id="matrix4">同意</div></th>
              <th><div>3</div><div class="small" id="matrix3">一般</div></th>
              <th><div>2</div><div class="small" id="matrix2">不同意</div></th>
              <th><div>1</div><div class="small" id="matrix1">非常不同意</div></th>
            </tr>
            <tr>
              <td id="attrPleasant">当前的声环境是愉悦的 Pleasant</td>
              <td><input type="radio" name="sound_attr_pleasant" value="5"></td>
              <td><input type="radio" name="sound_attr_pleasant" value="4"></td>
              <td><input type="radio" name="sound_attr_pleasant" value="3"></td>
              <td><input type="radio" name="sound_attr_pleasant" value="2"></td>
              <td><input type="radio" name="sound_attr_pleasant" value="1"></td>
            </tr>
            <tr>
              <td id="attrVibrant">当前的声环境是有活力的 Vibrant</td>
              <td><input type="radio" name="sound_attr_vibrant" value="5"></td>
              <td><input type="radio" name="sound_attr_vibrant" value="4"></td>
              <td><input type="radio" name="sound_attr_vibrant" value="3"></td>
              <td><input type="radio" name="sound_attr_vibrant" value="2"></td>
              <td><input type="radio" name="sound_attr_vibrant" value="1"></td>
            </tr>
            <tr>
              <td id="attrEventful">当前的声环境是有很多声事件的 Eventful</td>
              <td><input type="radio" name="sound_attr_eventful" value="5"></td>
              <td><input type="radio" name="sound_attr_eventful" value="4"></td>
              <td><input type="radio" name="sound_attr_eventful" value="3"></td>
              <td><input type="radio" name="sound_attr_eventful" value="2"></td>
              <td><input type="radio" name="sound_attr_eventful" value="1"></td>
            </tr>
            <tr>
              <td id="attrChaotic">当前的声环境是混乱的 Chaotic</td>
              <td><input type="radio" name="sound_attr_chaotic" value="5"></td>
              <td><input type="radio" name="sound_attr_chaotic" value="4"></td>
              <td><input type="radio" name="sound_attr_chaotic" value="3"></td>
              <td><input type="radio" name="sound_attr_chaotic" value="2"></td>
              <td><input type="radio" name="sound_attr_chaotic" value="1"></td>
            </tr>
            <tr>
              <td id="attrAnnoying">当前的声环境是令人烦恼的 Annoying</td>
              <td><input type="radio" name="sound_attr_annoying" value="5"></td>
              <td><input type="radio" name="sound_attr_annoying" value="4"></td>
              <td><input type="radio" name="sound_attr_annoying" value="3"></td>
              <td><input type="radio" name="sound_attr_annoying" value="2"></td>
              <td><input type="radio" name="sound_attr_annoying" value="1"></td>
            </tr>
            <tr>
              <td id="attrMonotonous">当前的声环境是单调的 Monotonous</td>
              <td><input type="radio" name="sound_attr_monotonous" value="5"></td>
              <td><input type="radio" name="sound_attr_monotonous" value="4"></td>
              <td><input type="radio" name="sound_attr_monotonous" value="3"></td>
              <td><input type="radio" name="sound_attr_monotonous" value="2"></td>
              <td><input type="radio" name="sound_attr_monotonous" value="1"></td>
            </tr>
            <tr>
              <td id="attrUneventful">当前的声环境是没什么声事件的 Uneventful</td>
              <td><input type="radio" name="sound_attr_uneventful" value="5"></td>
              <td><input type="radio" name="sound_attr_uneventful" value="4"></td>
