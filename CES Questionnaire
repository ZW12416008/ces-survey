  function renderRecentList() {
    const data = getStoredData();
    if (!data.length) {
      recentList.innerHTML = `<div class="recent-item">${t("recentEmpty")}</div>`;
      return;
    }
    const latest = data.slice(-5).reverse();
    recentList.innerHTML = latest.map(item => `
