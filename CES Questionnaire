    requireInPark = !enabled;
    localStorage.setItem(TEST_MODE_KEY, enabled ? "1" : "0");
    syncTestModeUI();

    if (shouldNotify) {
      alert(enabled ? t("dialogs.testModeOn") : t("dialogs.testModeOff"));
    }

    if (currentPosition) {
      if (inPark) {
        setStatusByKey("inPark", currentPosition.accuracy);
      } else if (requireInPark) {
        setStatusByKey("outParkReq", currentPosition.accuracy);
      } else {
        setStatusByKey("outParkTest", currentPosition.accuracy);
      }
    } else if (enabled) {
      setStatusByKey("testing");
    } else {
