<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zhongshan Park CES Survey / 中山公园 CES 问卷</title>

  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Microsoft YaHei", "PingFang SC", Arial, sans-serif;
      background: #f5f7fa;
      color: #222;
    }
    .page {
      display: flex;
      width: 100%;
      min-height: 100vh;
    }
    .map-panel {
      flex: 1 1 60%;
      position: relative;
      background: #ddd;
      min-height: 100vh;
    }
    #map {
      width: 100%;
      height: 100vh;
    }
    .toolbar {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 999;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }
    .toolbar button, .toolbar select {
      border: none;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 14px;
      box-shadow: 0 2px 8px rgba(0,0,0,.15);
    }
    .toolbar button {
      background: #1677ff;
      color: #fff;
      cursor: pointer;
    }
    .toolbar button.secondary {
      background: #555;
    }
    .toolbar .lang-select {
      background: #fff;
      color: #222;
      min-width: 146px;
      cursor: pointer;
    }
    .test-toggle-wrap {
      display: none;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.96);
      border-radius: 8px;
      padding: 8px 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,.15);
      font-size: 13px;
      color: #222;
    }
    .test-toggle-wrap input[type="checkbox"] {
      width: 16px;
      height: 16px;
      cursor: pointer;
    }
    .side-panel {
      flex: 0 0 560px;
      background: #fff;
      border-left: 1px solid #e5e7eb;
      padding: 20px;
      overflow-y: auto;
      max-height: 100vh;
    }
    h1 {
      margin: 0 0 10px;
      font-size: 24px;
    }
    h2 {
      margin: 22px 0 10px;
      font-size: 18px;
      padding-bottom: 6px;
      border-bottom: 1px solid #eee;
    }
    .desc, .status, .scale-note, .question-note, .lang-note {
      font-size: 13px;
      line-height: 1.7;
      color: #555;
    }
    .status {
      background: #f3f6fb;
      border: 1px solid #dbe5f2;
      border-radius: 8px;
      padding: 10px 12px;
      margin: 14px 0;
    }
    .scale-note, .question-note, .lang-note {
      background: #fafcff;
      border: 1px solid #e6ebf2;
      border-radius: 8px;
      padding: 8px 10px;
      margin-top: 6px;
    }
    .field {
      margin-bottom: 14px;
    }
    .field label {
      display: block;
      margin-bottom: 6px;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.7;
    }
    input[type="text"],
    input[type="number"],
    textarea,
    select {
      width: 100%;
      border: 1px solid #cfd8e3;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 14px;
      background: #fff;
    }
    textarea {
      min-height: 90px;
      resize: vertical;
    }
    .option-group {
      display: grid;
      gap: 8px;
      margin-top: 8px;
    }
    .option-inline {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 8px;
    }
    .option-inline label,
    .option-group label {
      font-weight: normal;
      font-size: 14px;
    }
    .inline-other {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .inline-other input[type="text"] {
      flex: 1;
      min-width: 180px;
    }
    .matrix {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
      font-size: 13px;
    }
    .matrix th, .matrix td {
      border: 1px solid #e5e7eb;
      padding: 8px;
      text-align: center;
      vertical-align: middle;
    }
    .matrix th:first-child,
    .matrix td:first-child,
    .matrix th:last-child,
    .matrix td:last-child {
      text-align: left;
      min-width: 140px;
    }
    .matrix .small {
      font-size: 12px;
      color: #666;
      line-height: 1.5;
    }
    .submit-row {
      display: flex;
      gap: 10px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .submit-row button {
      border: none;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 14px;
      cursor: pointer;
    }
    .primary { background: #16a34a; color: white; }
    .light { background: #eef2f7; color: #333; }
    .danger { background: #ef4444; color: #fff; }

    .recent {
      margin-top: 24px;
      padding-top: 14px;
      border-top: 1px solid #eee;
    }
    .recent-item {
      border: 1px solid #e6ebf2;
      border-radius: 8px;
      padding: 10px 12px;
      background: #fafcff;
      font-size: 13px;
      line-height: 1.6;
      margin-bottom: 8px;
    }

    .consent-mask {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 5000;
    }
    .consent-box {
      width: min(760px, 92vw);
      max-height: 86vh;
      overflow-y: auto;
      background: #fff;
      border-radius: 14px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(0,0,0,.22);
    }
    .consent-box h2 {
      margin-top: 0;
      border-bottom: none;
      padding-bottom: 0;
    }
    .consent-content {
      font-size: 14px;
      line-height: 1.9;
      color: #333;
      margin: 12px 0 16px;
      white-space: pre-line;
    }

    .hidden { display: none !important; }


    .display-banner {
      margin: 14px 0;
      background: #fff7e6;
      border: 1px solid #f5d08a;
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 13px;
      line-height: 1.8;
      color: #7a4b00;
    }
    .placeholder-box {
      border: 1px dashed #cfd8e3;
      border-radius: 10px;
      padding: 18px;
      background: #fafcff;
      color: #666;
      line-height: 1.8;
      font-size: 14px;
      margin-top: 10px;
      white-space: pre-line;
    }

    @media (max-width: 960px) {
      .page { flex-direction: column; }
      .map-panel { min-height: 50vh; }
      #map { height: 50vh; }
      .side-panel { width: 100%; max-height: none; }
    }
  </style>

  <script>
    window._AMapSecurityConfig = {
      securityJsCode: "98b0867d627993ffb76908cfd4ff9396"
    };
  </script>
